<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= titulo %> - Encuentra Mi Coche</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body class="d-flex flex-column min-vh-100 bg-parking">
    <%- include('partials/nav') %>

    <main class="container flex-grow-1 py-5">
        <div class="glass-card shadow-sm mb-4 p-4 d-flex justify-content-between align-items-center border-0" style="background: rgba(255, 255, 255, 0.9);">
            <div class="d-flex align-items-center">
                <div class="bg-primary bg-opacity-10 text-primary rounded-3 d-flex align-items-center justify-content-center me-3" style="width: 50px; height: 50px;">
                    <i class="bi bi-journals fs-3"></i>
                </div>
                <div>
                    <h2 class="h4 fw-bold mb-0 text-dark">Registro Histórico</h2>
                    <p class="text-muted small mb-0">Listado de tus aparcamientos anteriores</p>
                </div>
            </div>
            <button id="btn-borrar-historial" class="btn btn-outline-danger btn-hover-scale rounded-pill px-4">
                <i class="bi bi-trash3-fill me-2"></i>Limpiar Datos
            </button>
        </div>
        
        <div class="glass-card shadow-lg overflow-hidden border-0" style="background: rgba(255, 255, 255, 0.9);">
            <div class="table-responsive">
                <table class="table table-borderless align-middle mb-0">
                    <thead class="bg-light bg-opacity-75 border-bottom">
                        <tr>
                            <th class="ps-4 py-3 text-secondary text-uppercase small fw-bold">Fecha del Registro</th>
                            <th class="py-3 text-secondary text-uppercase small fw-bold">Coordenadas GPS</th>
                            <th class="text-end pe-4 py-3 text-secondary text-uppercase small fw-bold">Acción</th>
                        </tr>
                    </thead>
                    <tbody id="tabla-historial">
                        </tbody>
                </table>
            </div>
            
            <div id="sin-datos" class="text-center py-5 d-none">
                <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                    <i class="bi bi-inbox-fill text-secondary opacity-50" style="font-size: 2.5rem;"></i>
                </div>
                <h5 class="text-dark fw-bold">Historial Vacío</h5>
                <p class="text-muted mb-0">Aún no has finalizado ninguna sesión de aparcamiento.</p>
            </div>
        </div>
    </main>

    <%- include('partials/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/javascripts/app.js"></script>
</body>
</html>
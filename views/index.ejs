<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= titulo %> - Encuentra Mi Coche</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body class="d-flex flex-column vh-100 overflow-hidden bg-parking">
    <%- include('partials/nav') %>

    <main class="container-fluid flex-grow-1 d-flex flex-column align-items-center justify-content-center p-3">
        
        <div class="text-center mb-4">
            <h1 class="display-6 fw-bold text-white mb-1"><i class="bi bi-geo-alt-fill text-primary me-2"></i>Bienvenido</h1>
            <p class="text-light fs-4 mb-0 opacity-75">Gestiona la ubicación de tu vehículo</p>
        </div>

        <div class="card glass-card shadow-lg w-100 border-0" style="max-width: 450px; background: rgba(255, 255, 255, 0.9);">
            <div class="card-body text-center p-4">
                
                <div id="info-aparcado" class="d-none mb-3">
                    <div class="badge bg-success bg-opacity-10 text-success border border-success rounded-pill px-3 py-2 mb-3 fs-6">
                        <i class="bi bi-shield-check me-2"></i>Vehículo Seguro
                    </div>
                    
                    <div class="widget-stat p-3 mb-3 shadow-sm">
                        <p class="text-white-50 small text-uppercase fw-bold mb-1"><i class="bi bi-stopwatch me-1"></i>Tiempo Transcurrido</p>
                        <p class="display-5 fw-bolder mb-0" id="timer">00:00:00</p>
                    </div>

                    <div class="d-flex justify-content-between align-items-center bg-light p-3 rounded-3 border">
                        <span class="text-secondary fw-medium"><i class="bi bi-rulers me-2"></i>Distancia a pie</span>
                        <span class="fw-bold fs-5 text-dark"><span id="distancia-texto">0</span> m</span>
                    </div>
                </div>

                <button id="btn-aparcar" class="btn btn-primary btn-lg w-100 py-3 rounded-pill btn-hover-scale shadow-sm fw-bold">
                    <i class="bi bi-pin-map-fill me-2"></i>Aparcar Vehículo Aquí
                </button>
                <button id="btn-finalizar" class="btn btn-danger btn-lg w-100 py-3 rounded-pill btn-hover-scale shadow-sm fw-bold d-none mt-3">
                    <i class="bi bi-stop-circle me-2"></i>Terminar Sesión
                </button>
            </div>
        </div>
    </main>

    <%- include('partials/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/javascripts/app.js"></script>
</body>
</html>
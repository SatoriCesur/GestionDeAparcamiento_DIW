<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= titulo %> - Encuentra Mi Coche</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body class="d-flex flex-column vh-100 overflow-hidden bg-parking">
    <%- include('partials/nav') %>

    <main class="container-fluid flex-grow-1 d-flex align-items-center justify-content-center p-3">
        <div class="card glass-card shadow-lg w-100 border-0" style="max-width: 450px; background: rgba(255, 255, 255, 0.95);">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3 shadow" style="width: 70px; height: 70px;">
                        <i class="bi bi-person-lock fs-1"></i>
                    </div>
                    <h2 class="h3 fw-bold text-dark">Sincronización</h2>
                    <p class="text-muted fs-6">Inicia sesión para respaldar tus datos en la nube.</p>
                </div>

                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="alert alert-danger shadow-sm py-2 mb-4 text-center fs-6">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i><%= error %>
                    </div>
                <% } %>

                <form action="/login" method="POST">
                    <div class="mb-4">
                        <label class="form-label text-secondary fw-bold fs-6">Usuario</label>
                        <div class="input-group input-group-lg shadow-sm">
                            <span class="input-group-text bg-white"><i class="bi bi-person text-muted"></i></span>
                            <input type="text" name="usuario" class="form-control border-start-0 ps-0 fs-5" placeholder="Tu nombre" required>
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label text-secondary fw-bold fs-6">Contraseña</label>
                        <div class="input-group input-group-lg shadow-sm">
                            <span class="input-group-text bg-white"><i class="bi bi-key text-muted"></i></span>
                            <input type="password" name="password" class="form-control border-start-0 ps-0 fs-5" placeholder="********" required>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary btn-lg w-100 py-3 rounded-pill btn-hover-scale fw-bold shadow-sm fs-5">
                        Acceder
                    </button>
                </form>

                <div class="text-center mt-4 pt-4 border-top">
                    <a href="/" class="text-decoration-none text-muted fs-6"><i class="bi bi-arrow-left me-2"></i>Continuar sin cuenta</a>
                </div>
            </div>
        </div>
    </main>

    <%- include('partials/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>